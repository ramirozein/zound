/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
pnpm-lock.yaml
pnpm-workspace.yaml


# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

*.sqlite
*.sqlite-journal
*.db
*.db-journal

# misc
*.log

# env files - Ignore all environment variables specifically
.env
.env.*
!.env.example

# Android / Capacitor specific
android/app/google-services.json
android/app/build/
android/.gradle/
android/.idea/
android/local.properties
android/*.iml

# iOS / Capacitor (if added later)
ios/App/App/public
ios/App/Pods/
ios/App/.build/
ios/App/build/
ios/App/DerivedData/
ios/capacitor-cordova-ios-plugins/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

